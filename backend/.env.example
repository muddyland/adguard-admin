# ---- Core ----
APP_NAME=AdGuard Admin
DATABASE_URL=sqlite:///./adguard_admin.db

# ---- Security (CHANGE THESE) ----
# Long random string for signing JWTs and sessions:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-generate-a-long-random-string
# Fernet key to encrypt AdGuard server passwords at rest:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---- Bootstrap admin (created only on first run) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ---- Reconciliation ----
SYNC_INTERVAL_SECONDS=60
DEFAULT_PRUNE=false

# ---- Provisioning ----
# Public URL of THIS admin app, reachable by the servers you provision.
# The one-line install command and the script's callbacks use this.
PUBLIC_BASE_URL=http://localhost:8000
PROVISION_TOKEN_TTL_HOURS=24

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ---- OIDC / Authentik (optional) ----
OIDC_ENABLED=false
OIDC_ISSUER=https://authentik.example.com/application/o/adguard-admin/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback
OIDC_DEFAULT_ROLE=viewer
OIDC_ADMIN_GROUP=adguard-admins
